# Neon PostgreSQL connection string (pooled).
# Get this from the Neon dashboard → Connection Details → Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Secret used to sign session JWTs. Generate one with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"
